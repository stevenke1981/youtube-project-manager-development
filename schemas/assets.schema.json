{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "YTPM Assets",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assets"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "relative_path",
          "display_name",
          "state",
          "source_type",
          "size_bytes",
          "sha256",
          "duration_ms",
          "width",
          "height",
          "generator",
          "model",
          "prompt",
          "version_group_id",
          "version_number",
          "is_adopted",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "kind": {
            "enum": [
              "research",
              "script",
              "voice",
              "music",
              "sound_effect",
              "image",
              "video",
              "subtitle",
              "thumbnail",
              "metadata",
              "export",
              "other"
            ]
          },
          "relative_path": {
            "type": "string",
            "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*[<>:\"|?*\\u0000-\\u001F]).+$"
          },
          "display_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "state": {
            "enum": [
              "available",
              "missing",
              "archived",
              "processing",
              "error"
            ]
          },
          "source_type": {
            "enum": [
              "created",
              "imported",
              "generated",
              "linked",
              "downloaded",
              null
            ],
            "type": [
              "string",
              "null"
            ]
          },
          "generator": {
            "type": [
              "string",
              "null"
            ]
          },
          "model": {
            "type": [
              "string",
              "null"
            ]
          },
          "prompt": {
            "type": [
              "string",
              "null"
            ]
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "duration_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "width": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "height": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "version_group_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "version_number": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "is_adopted": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
