{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ytpm.local/schemas/project.schema.json",
  "title": "YTPM Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "folder_name",
    "status",
    "archived_from_status",
    "aspect_ratio",
    "language",
    "progress",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "folder_name": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": [
        "string",
        "null"
      ]
    },
    "series": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "idea",
        "research",
        "script",
        "voice",
        "visuals",
        "editing",
        "subtitles",
        "thumbnail",
        "review",
        "scheduled",
        "published",
        "archived"
      ]
    },
    "archived_from_status": {
      "anyOf": [
        {
          "enum": [
            "idea",
            "research",
            "script",
            "voice",
            "visuals",
            "editing",
            "subtitles",
            "thumbnail",
            "review",
            "scheduled",
            "published",
            "archived"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "aspect_ratio": {
      "enum": [
        "16:9",
        "9:16",
        "1:1",
        "4:3",
        "custom"
      ]
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "target_duration_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "planned_publish_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "progress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "app_version": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
